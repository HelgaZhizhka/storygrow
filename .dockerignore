# Build context is the repo root for both backend/Dockerfile and frontend/Dockerfile.
**/node_modules
**/dist
**/.next
# Generated Prisma client — always regenerated during the build (postinstall),
# so never copy a local copy in (keeps the build consistent with CI/Railway).
backend/src/generated
**/.turbo
**/coverage
**/playwright-report
**/test-results
.git
.github
**/.env
**/.env.*
!**/.env.example
**/*.log
