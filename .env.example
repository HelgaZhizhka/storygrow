# StoryGrow — local development environment.
# Copy to .env.local and fill in real values for secrets (OPENAI, GOOGLE, STRIPE).
# .env*.local is gitignored — never commit real keys.

# --- Postgres (pgvector) ---
# Matches the postgres service in docker-compose.yml. Override POSTGRES_*
# at compose time if you want a different role/password than the defaults.
POSTGRES_USER=storygrow
POSTGRES_PASSWORD=storygrow
POSTGRES_DB=storygrow
DATABASE_URL=postgresql://storygrow:storygrow@localhost:5432/storygrow

# --- Redis (BullMQ queues) ---
REDIS_URL=redis://localhost:6379

# --- S3 / MinIO (book assets, illustrations, PDFs) ---
S3_ENDPOINT=http://localhost:9100
S3_ACCESS_KEY=storygrow
S3_SECRET_KEY=storygrow-dev-secret
S3_BUCKET=storygrow

# --- OpenAI (text + judge + embeddings + DALL-E) ---
OPENAI_API_KEY=sk-...

# --- Image generation provider: gemini (default) | openai ---
IMAGE_PROVIDER=gemini
# Gemini API key from Google AI Studio (billing-enabled project) — NOT the OAuth client
GOOGLE_GENERATIVE_AI_API_KEY=

# --- LangFuse (self-hosted observability) ---
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_ENABLED=false  # set to 'false' to disable LangFuse tracing (e.g. in local dev without LangFuse running)
# Used by the langfuse container itself; rotate before any real deployment.
LANGFUSE_NEXTAUTH_SECRET=dev-secret-change-me
LANGFUSE_SALT=dev-salt-change-me
# First-run bootstrap of the LangFuse admin user (consumed only on first start).
LANGFUSE_INIT_USER_EMAIL=admin@storygrow.local
LANGFUSE_INIT_USER_PASSWORD=changeme123

# --- Auth (Google OAuth → JWT sessions) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
JWT_SECRET=dev-jwt-secret-change-me
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-me
FRONTEND_URL=http://localhost:3000

# --- Stripe (payments, webhooks) --- single Premium tier, #268
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# --- Evaluation (LLM-as-judge thresholds) ---
EVAL_THRESHOLD=7.0
EVAL_MAX_RETRIES=2
